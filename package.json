{
  "name": "hub-jogos-pre-campanha",
  "version": "0.0.1",
  "description": "PWA - Hub de Jogos e Experiências Interativas para Pré-Campanha de Alexandre Fonseca para Deputado",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "test:ci": "npm run test:unit && npm run test:e2e",
    "type-check": "tsc --noEmit",
    "verify": "node tools/verify.js && npm run lint && npm run type-check && npm run test:unit && npm run build",
    "report": "node tools/generate-report.js",
    "beta:snapshot": "node tools/beta-snapshot.js",
    "beta:export": "node tools/beta-export.js",
    "beta:circulation-report": "node tools/beta-circulation-report.js",
    "beta:distribution-report": "node tools/beta-distribution-report.js",
    "beta:readiness-report": "node tools/beta-readiness-report.js",
    "beta:staleness-check": "node tools/beta-staleness-check.js",
    "beta:ops": "node tools/beta-ops.js",
    "campaign:links": "node tools/generate-campaign-links.js",
    "beta:campaign-brief": "node tools/beta-campaign-brief.js",
    "campaign:brief": "node tools/beta-campaign-brief.js",
    "beta:arcade-final-decision": "node tools/beta-arcade-final-decision.js",
    "ops:apply-migration": "node tools/apply-tijolo-14-migration.js",
    "ops:export-config": "node tools/export-experiments-config.js",
    "ops:check-alerts": "node tools/ops-check-alerts.js",
    "ops:export-audit": "node tools/ops-export-audit.js"
  },
  "keywords": [
    "pwa",
    "jogos",
    "campanha-politica",
    "next.js",
    "react",
    "interactive"
  ],
  "author": "Hub de Jogos Pré-Campanha de Alexandre Fonseca para Deputado Team",
  "license": "MIT",
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@sentry/nextjs": "^10.42.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "html-to-image": "^1.11.13",
    "next": "^14.2.35",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^14.2.35",
    "@playwright/test": "^1.58.2",
    "@supabase/supabase-js": "^2.98.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  }
}
